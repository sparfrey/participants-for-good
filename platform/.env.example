# Copy to .env (or set in Railway) and fill in for production.
# With none of these set, the app runs in dev mode: magic links are shown
# on-screen instead of emailed, and cookies are not marked Secure.

NODE_ENV=development
PORT=4519

# Where the SQLite database lives. On Railway, point this at the mounted volume.
DATABASE_PATH=./data.db

# Production email delivery for magic links (Resend). Unset = dev mode.
RESEND_API_KEY=
MAIL_FROM="Participants for Good <hello@participantsforgood.org>"

# Absolute origin used in emailed links, e.g. https://app.participantsforgood.org
APP_ORIGIN=http://localhost:4519

# Comma-separated emails that get the admin role on sign-in. REQUIRED in
# production; if unset in dev, every signed-in user is treated as admin locally.
ADMIN_EMAILS=

